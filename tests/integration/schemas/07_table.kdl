@doc "Focused coverage: table structs, @rows/@match/@value and table-specific predicates."

define CSS-TABLE="table.coverage"
define RE-FLOAT=#"(\d+\.\d+)"#
define RE-CODE=#"^code"#

struct TableCoverage type=table {
    @pre-validate {
        assert {
            css "table.coverage tr"
        }
    }

    @table {
        css CSS-TABLE
    }

    @rows {
        css-all "tr"
    }

    @match {
        css "th"
        text
        trim
        lower
    }

    @value {
        css "td"
        text
        trim
    }

    identifier {
        match {
            eq "id" "identifier"
        }
    }

    code-value {
        match {
            re RE-CODE
        }
    }

    price {
        match {
            starts "price"
            contains "price" "amount"
            not {
                eq "price-old"
            }
        }
        re RE-FLOAT
        to-float
        fallback 0.0
    }

    tax-or-fee {
        match {
            ends "tax" "fee"
        }
        re RE-FLOAT
        to-float
        fallback 0.0
    }

    state {
        match {
            in "state" "status"
            ne "skip" "ignore"
        }
        lower
        fallback ""
    }
}
